# ─── Database ───────────────────────────────────────────────────────────────
# Supabase connection string (Session mode, port 5432)
# Format: postgresql+asyncpg://[user]:[password]@[host]:[port]/[db]?sslmode=require
DATABASE_URL=postgresql+asyncpg://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres

# ─── Google Sheets — Auth method ────────────────────────────────────────────
# "oauth" (default) — browser login, no key file needed (recommended for personal use)
# "service_account" — service account JSON key (for servers/CI)
GOOGLE_AUTH_METHOD=oauth

# ─── OAuth 2.0 (used when GOOGLE_AUTH_METHOD=oauth) ─────────────────────────
# Create an OAuth 2.0 Desktop app credential at:
#   console.cloud.google.com → APIs & Services → Credentials → Create Credentials → OAuth client ID
# Choose "Desktop app", then copy the Client ID and Client Secret below.
GOOGLE_CLIENT_ID=YOUR_CLIENT_ID.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=YOUR_CLIENT_SECRET
# Where to cache the OAuth token after first login (never commit this file)
GOOGLE_TOKEN_PATH=.oauth_token.json

# ─── Service account (used when GOOGLE_AUTH_METHOD=service_account) ─────────
# Path to the downloaded service account JSON key file (never commit this file)
GOOGLE_CREDENTIALS_PATH=credentials.json

# ─── App ────────────────────────────────────────────────────────────────────
APP_ENV=development
