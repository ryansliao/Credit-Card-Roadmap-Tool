# ─── Database ────────────────────────────────────────────────────────────────
# Azure Database for PostgreSQL connection string
DATABASE_URL=postgresql+asyncpg://[USERNAME]:[PASSWORD]@[SERVER].postgres.database.azure.com:5432/postgres?ssl=require

# ─── App ─────────────────────────────────────────────────────────────────────
APP_ENV=development

# ─── Authentication ─────────────────────────────────────────────────────────
# Google OAuth2 Client ID (from Google Cloud Console → Credentials)
GOOGLE_CLIENT_ID=
# Same Client ID, VITE_ prefix so the frontend can read it at build time
VITE_GOOGLE_CLIENT_ID=
# Secret key for signing JWT session tokens (any random string; keep it secret)
JWT_SECRET=

# ─── CORS ────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins (defaults to localhost:5173 in dev)
# In production set this to your Azure Static Web App or App Service URL
ALLOWED_ORIGINS=http://localhost:5173
